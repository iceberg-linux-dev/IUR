# --- HELPERS ----------------------------------------------------------

def require_root():
    if os.geteuid() != 0:
        print(f"{RED}  ✗ ipm needs root for this command. Run with sudo.{RESET}")
        sys.exit(1)

def pacman(*args, capture=False):
    """Thin wrapper around pacman."""
    if capture:
        cmd = ['pacman'] + list(args)
    else:
        cmd = ['pacman', '--color=always'] + list(args)

    if capture:
        return subprocess.run(cmd, capture_output=True, text=True)
    return subprocess.run(cmd)

def confirm(prompt):
    """Simple y/n prompt. Returns True if user confirms."""
    ans = input(f"{YELLOW}  ? {prompt} [y/N]: {RESET}").strip().lower()
    return ans in ('y', 'yes')

def print_section(title):
    width = 48
    print(f"\n{CYAN}{'─' * width}{RESET}")
    print(f"{BOLD}{WHITE}  {title}{RESET}")
    print(f"{CYAN}{'─' * width}{RESET}")

# --- COMMANDS ---------------------------------------------------------

def cmd_submerge(packages):
    """Install one or more packages."""
    if not packages:
        print(f"{RED}  ✗ Usage: ipm submerge <package> [package...]{RESET}")
        sys.exit(1)
    require_root()
    print_section(f"Submerging: {', '.join(packages)}")
    print(f"{DIM}  Pushing packages beneath the surface...{RESET}\n")
    result = pacman('-S', '--needed', *packages)
    if result.returncode == 0:
        print(f"\n{GREEN}  ✓ Submerged successfully.{RESET}")
    else:
        print(f"\n{RED}  ✗ Something surfaced wrong. Check the output above.{RESET}")
        sys.exit(result.returncode)

def cmd_melt(packages):
    """Uninstall one or more packages."""
    if not packages:
        print(f"{RED}  ✗ Usage: ipm melt <package> [package...]{RESET}")
        sys.exit(1)
    require_root()
    print_section(f"Melting: {', '.join(packages)}")
    print(f"{YELLOW}  ⚠  This will remove: {', '.join(packages)}{RESET}")
    if not confirm("Continue with melt?"):
        print(f"{DIM}  Aborted. The ice holds.{RESET}")
        sys.exit(0)
    print(f"{DIM}  Melting away...{RESET}\n")
    result = pacman('-Rns', *packages)
    if result.returncode == 0:
        print(f"\n{GREEN}  ✓ Melted clean.{RESET}")
    else:
        print(f"\n{RED}  ✗ Melt incomplete. Check the output above.{RESET}")
        sys.exit(result.returncode)

def cmd_dive():
    """Full system update."""
    require_root()
    print_section("Diving Deeper — System Update")
    print(f"{DIM}  Syncing mirrors and pulling the latest...{RESET}\n")
    result = pacman('-Syu')
    if result.returncode == 0:
        print(f"\n{GREEN}  ✓ Surfaced with everything up to date.{RESET}")
    else:
        print(f"\n{RED}  ✗ Something went wrong mid-dive.{RESET}")
        sys.exit(result.returncode)

def cmd_surface(packages):
    """Search for a package by name or description."""
    if not packages:
        print(f"{RED}  ✗ Usage: ipm surface <query>{RESET}")
        sys.exit(1)

    query = ' '.join(packages)
    print_section(f"Surfacing results for: {query}")
    print(f"{DIM}  Scanning the depths...{RESET}\n")

    result = pacman('-Ss', *packages, capture=True)

    if result.stdout.strip():
        lines = result.stdout.strip().split('\n')
        i = 0
        while i < len(lines):
            if not lines[i].strip() or lines[i].startswith('warning:'):
                i += 1
                continue

            pkg_line  = lines[i]
            desc_line = lines[i + 1] if i + 1 < len(lines) else ''
            parts = pkg_line.split()

            if parts and '/' in parts[0]:
                pkg_id  = parts[0]
                version = parts[1] if len(parts) > 1 else ''
                flags   = ' '.join(parts[2:]) if len(parts) > 2 else ''
                repo, _, name = pkg_id.partition('/')
                installed_tag = f" {GREEN}[installed]{RESET}" if '[installed]' in flags else ''
                print(f"  {CYAN}{repo}/{RESET}{BOLD}{name}{RESET} {DIM}{version}{RESET}{installed_tag}")
                if desc_line and not desc_line.startswith('warning:'):
                    print(f"    {DIM}{desc_line.strip()}{RESET}\n")
                i += 2
            else:
                i += 1
    else:
        print(f"  {YELLOW}No packages found for '{query}'.{RESET}")

def cmd_depth(package):
    """Show detailed info about a package."""
    if not package:
        print(f"{RED}  ✗ Usage: ipm depth <package>{RESET}")
        sys.exit(1)
    print_section(f"Depth reading: {package}")
    result = pacman('-Qi', package, capture=True)
    if result.returncode != 0:
        result = pacman('-Si', package, capture=True)
    if result.returncode == 0:
        for line in result.stdout.splitlines():
            if ':' in line:
                key, _, val = line.partition(':')
                print(f"  {CYAN}{key.strip():<20}{RESET}: {val.strip()}")
            elif line.strip():
                print(f"  {'':<20}  {DIM}{line.strip()}{RESET}")
    else:
        print(f"  {RED}Package '{package}' not found.{RESET}")
        sys.exit(1)

def cmd_iceberg():
    """List all explicitly installed packages."""
    print_section("Your Iceberg — Installed Packages")
    print(f"{DIM}  Everything frozen into this system:{RESET}\n")
    result = pacman('-Qe', capture=True)
    if result.returncode == 0:
        lines = result.stdout.strip().split('\n')
        for line in lines:
            parts = line.split()
            if parts:
                name    = parts[0]
                version = parts[1] if len(parts) > 1 else ''
                print(f"  {CYAN}❄{RESET}  {BOLD}{name:<30}{RESET} {DIM}{version}{RESET}")
        print(f"\n{DIM}  {len(lines)} package(s) on the iceberg.{RESET}")
    else:
        print(f"  {RED}Could not list packages.{RESET}")
        sys.exit(1)

def cmd_freeze(packages):
    """Hold packages so they won't be updated."""
    if not packages:
        print(f"{RED}  ✗ Usage: ipm freeze <package> [package...]{RESET}")
        sys.exit(1)
    require_root()
    print_section(f"Freezing: {', '.join(packages)}")
    try:
        with open('/etc/pacman.conf', 'r') as f:
            lines = f.readlines()

        found = False
        for i, line in enumerate(lines):
            if re.match(r'^\s*IgnorePkg\s*=', line):
                existing_pkgs = line.split('=', 1)[1].strip().split()
                new_pkgs = list(set(existing_pkgs + packages))
                lines[i] = f'IgnorePkg = {" ".join(new_pkgs)}\n'
                found = True
                break

        if not found:
            lines.append(f'\nIgnorePkg = {" ".join(packages)}\n')

        with open('/etc/pacman.conf', 'w') as f:
            f.writelines(lines)

        print(f"  {GREEN}✓ Frozen: {', '.join(packages)}{RESET}")
        print(f"  {DIM}Added to IgnorePkg in /etc/pacman.conf{RESET}")
    except Exception as e:
        print(f"  {RED}✗ Could not update pacman.conf: {e}{RESET}")
        sys.exit(1)

def cmd_thaw(packages):
    """Remove hold from packages."""
    if not packages:
        print(f"{RED}  ✗ Usage: ipm thaw <package> [package...]{RESET}")
        sys.exit(1)
    require_root()
    print_section(f"Thawing: {', '.join(packages)}")
    try:
        with open('/etc/pacman.conf', 'r') as f:
            lines = f.readlines()

        found = False
        for i, line in enumerate(lines):
            if re.match(r'^\s*IgnorePkg\s*=', line):
                existing_pkgs = set(line.split('=', 1)[1].strip().split())
                updated_pkgs = existing_pkgs - set(packages)

                if updated_pkgs:
                    lines[i] = f'IgnorePkg = {" ".join(sorted(updated_pkgs))}\n'
                else:
                    lines[i] = '#IgnorePkg =\n'

                removed = existing_pkgs & set(packages)
                not_held = set(packages) - existing_pkgs
                if removed:
                    print(f"  {GREEN}✓ Thawed: {', '.join(sorted(removed))}{RESET}")
                if not_held:
                    print(f"  {YELLOW}  Not frozen: {', '.join(sorted(not_held))}{RESET}")
                found = True
                break

        if not found:
            print(f"  {YELLOW}  No packages are currently frozen.{RESET}")
        else:
            with open('/etc/pacman.conf', 'w') as f:
                f.writelines(lines)

    except Exception as e:
        print(f"  {RED}✗ Could not update pacman.conf: {e}{RESET}")
        sys.exit(1)

def cmd_link():
    """Creates a system shortcut so you can just type 'installer'."""
    require_root()
    print_section("Creating Installer Shortcut")
    script_path = os.path.abspath(sys.argv[0])
    try:
        subprocess.run(['ln', '-sf', script_path, '/usr/local/bin/installer'], check=True)
        print(f"  {GREEN}✓ Shortcut created successfully!{RESET}")
        print(f"  {DIM}You can now just type '{BOLD}installer{RESET}{DIM}' in the terminal to launch it.{RESET}")
    except subprocess.CalledProcessError:
        print(f"  {RED}✗ Failed to create symlink. Are you running as root?{RESET}")

