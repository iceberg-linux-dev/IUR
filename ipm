def require_root():
    if os.geteuid() != 0:
        print(f"{RED}  ✗ ipm needs root for this command. Run with sudo.{RESET}")
        sys.exit(1)

def pacman(*args, capture=False):
    cmd = ['pacman', '--color=always'] + list(args) if not capture else ['pacman'] + list(args)
    return subprocess.run(cmd, capture_output=True, text=True) if capture else subprocess.run(cmd)

def confirm(prompt):
    return input(f"{YELLOW}  ? {prompt} [y/N]: {RESET}").strip().lower() in ('y', 'yes')

def print_section(title):
    print(f"\n{CYAN}{'─' * 48}{RESET}\n{BOLD}{WHITE}  {title}{RESET}\n{CYAN}{'─' * 48}{RESET}")

def get_partition_names(drive):
    return f'{drive}p1', f'{drive}p2', f'{drive}p3' if 'nvme' in drive or 'mmcblk' in drive else f'{drive}1', f'{drive}2', f'{drive}3'

def is_efi():
    return subprocess.run(['ls', '/sys/firmware/efi'], capture_output=True).returncode == 0

def detect_os(drive):
    result = subprocess.run(['lsblk', '-J', '-o', 'NAME,FSTYPE,TYPE'], capture_output=True, text=True)
    for disk in json.loads(result.stdout)['blockdevices']:
        if disk['name'] == drive.replace('/dev/', ''):
            for part in disk.get('children', []):
                if part.get('fstype') in ['ext4', 'btrfs', 'xfs', 'ntfs', 'f2fs']:
                    return True
    return False

def get_ucode():
    try:
        result = subprocess.run(['grep', '-m1', 'vendor_id', '/proc/cpuinfo'], capture_output=True, text=True)
        if 'Intel' in result.stdout: return 'intel-ucode'
        elif 'AMD' in result.stdout: return 'amd-ucode'
    except Exception: pass
    return None

def bind_mounts():
    for fs in ['proc', 'sys', 'dev', 'dev/pts', 'run']:
        subprocess.run(['mkdir', '-p', f'/mnt/{fs}'])
        subprocess.run(['mount', '--bind', f'/{fs}', f'/mnt/{fs}'])
    if is_efi():
        subprocess.run(['mkdir', '-p', '/mnt/sys/firmware/efi/efivars'])
        subprocess.run(['mount', '--bind', '/sys/firmware/efi/efivars', '/mnt/sys/firmware/efi/efivars'])

