def detect_wifi_chip():
    try:
        result = subprocess.run(['lspci', '-nnk'], capture_output=True, text=True)
        output = result.stdout.lower()
        if 'marvell' in output or '88w' in output: return 'marvell', 'mwifiex_pcie'
        elif 'realtek' in output or 'rtl88' in output or 'rtl87' in output: return 'realtek', 'rtw88'
        elif 'broadcom' in output or 'bcm43' in output: return 'broadcom', 'brcmfmac'
        elif 'mediatek' in output or 'mt76' in output or 'mt79' in output: return 'mediatek', 'mt76'
        elif 'intel' in output and ('wireless' in output or 'wi-fi' in output): return 'intel', 'iwlwifi'
        elif 'qualcomm' in output or 'atheros' in output: return 'qualcomm', 'ath10k'
        return 'unknown', 'generic'
    except Exception:
        return 'unknown', 'generic'

def load_wifi_firmware(vendor):
    print(f"{DIM}  Detected WiFi vendor: {BOLD}{vendor.upper()}{RESET}")
    firmware_map = {
        'marvell': ['mwifiex', 'mwifiex_pcie', 'mrvl_sdio'],
        'realtek': ['rtw88_8822ce', 'rtw88_8821ce', 'rtl8xxxu'],
        'broadcom': ['brcmfmac'],
        'mediatek': ['mt76', 'mt7921e'],
        'intel': ['iwlwifi'],
        'qualcomm': ['ath10k_pci', 'ath11k']
    }
    for mod in firmware_map.get(vendor, []):
        if subprocess.run(['modprobe', mod], capture_output=True).returncode == 0:
            print(f"{GREEN}  ✓ Loaded module: {mod}{RESET}")
            time.sleep(1)
            return True
    print(f"{YELLOW}  ⚠ Could not auto-load firmware. Ensure 'linux-firmware' is installed.{RESET}")
    return False

def connect_wifi_auto():
    vendor, _ = detect_wifi_chip()
    load_wifi_firmware(vendor)
    
    subprocess.run(['systemctl', 'start', 'NetworkManager'], capture_output=True)
    time.sleep(1)
    subprocess.run(['nmcli', 'radio', 'wifi', 'on'], capture_output=True)
    subprocess.run(['rfkill', 'unblock', 'wifi'], capture_output=True)
    time.sleep(2)
    
    # Nuke-proof: Check if we already have internet before trying anything else
    if subprocess.run(['ping', '-c', '1', '-W', '2', '8.8.8.8'], capture_output=True).returncode == 0:
        print(f"{GREEN}  ✓ Internet connection already active!{RESET}")
        return True

    print(f"\n{BOLD}  WiFi Setup{RESET}")
    print(f"{DIM}  (Tip: You can also just press Enter to use the visual nmtui menu){RESET}")
    ssid = input(f"  Enter WiFi SSID: ").strip()
    
    # If they just press Enter, go straight to the foolproof visual menu
    if not ssid:
        print(f"{DIM}  Opening visual network manager...{RESET}")
        subprocess.run(['nmtui'])
        if subprocess.run(['ping', '-c', '1', '-W', '2', '8.8.8.8'], capture_output=True).returncode == 0:
            print(f"{GREEN}  ✓ Connected successfully via nmtui!{RESET}")
            return True
        return False
        
    password = input(f"  Enter Password: ").strip()
    print(f"{DIM}  Connecting to {ssid}...{RESET}")
    result = subprocess.run(['nmcli', 'device', 'wifi', 'connect', ssid, 'password', password], capture_output=True, text=True)
    time.sleep(3)
    
    if subprocess.run(['ping', '-c', '1', '-W', '2', '8.8.8.8'], capture_output=True).returncode == 0:
        print(f"{GREEN}  ✓ Connected successfully!{RESET}")
        return True
    
    err = result.stderr.strip() if result.stderr.strip() else "Connection failed (Check password or signal)"
    print(f"{RED}  ✗ Connection failed: {err}{RESET}")
    
    print(f"{DIM}  Falling back to visual network menu...{RESET}")
    subprocess.run(['nmtui'])
    if subprocess.run(['ping', '-c', '1', '-W', '2', '8.8.8.8'], capture_output=True).returncode == 0:
        print(f"{GREEN}  ✓ Connected successfully!{RESET}")
        return True
        
    return False

def check_wifi():
    print(f"{DIM}  Testing internet connection...{RESET}")
    if subprocess.run(['ping', '-c', '1', '-W', '2', '8.8.8.8'], capture_output=True).returncode == 0:
        return True
    print(f"{RED}  ✗ No internet detected.{RESET}")
    if input("  Configure WiFi now? (yes/no): ").strip().lower() == 'yes':
        return connect_wifi_auto()
    return False

