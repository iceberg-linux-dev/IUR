def get_partition_names(drive):
    if 'nvme' in drive or 'mmcblk' in drive:
        return f'{drive}p1', f'{drive}p2', f'{drive}p3'
    else:
        return f'{drive}1', f'{drive}2', f'{drive}3'

def is_efi():
    result = subprocess.run(['ls', '/sys/firmware/efi'], capture_output=True)
    return result.returncode == 0

def detect_os(drive):
    result = subprocess.run(['lsblk', '-J', '-o', 'NAME,FSTYPE,TYPE'], capture_output=True, text=True)
    data   = json.loads(result.stdout)
    drive_name = drive.replace('/dev/', '')
    for disk in data['blockdevices']:
        if disk['name'] == drive_name:
            for part in disk.get('children', []):
                if part.get('fstype') in ['ext4', 'btrfs', 'xfs', 'ntfs', 'f2fs']:
                    return True
    return False

def get_ucode():
    try:
        result = subprocess.run(['grep', '-m1', 'vendor_id', '/proc/cpuinfo'],
                                capture_output=True, text=True)
        if 'Intel' in result.stdout:
            return 'intel-ucode'
        elif 'AMD' in result.stdout:
            return 'amd-ucode'
    except Exception:
        pass
    return None

def bind_mounts():
    print("Binding virtual filesystems...")
    for fs in ['proc', 'sys', 'dev', 'dev/pts', 'run']:
        subprocess.run(['mkdir', '-p', f'/mnt/{fs}'])
        subprocess.run(['mount', '--bind', f'/{fs}', f'/mnt/{fs}'])
    if is_efi():
        subprocess.run(['mkdir', '-p', '/mnt/sys/firmware/efi/efivars'])
        subprocess.run(['mount', '--bind', '/sys/firmware/efi/efivars',
                        '/mnt/sys/firmware/efi/efivars'])

