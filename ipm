def auto_partition(drive):
    p1, p2, p3 = get_partition_names(drive)
    print("\nCreating partitions...")
    subprocess.run(['parted', '-s', drive, 'mklabel', 'gpt'])
    subprocess.run(['parted', '-s', drive, 'mkpart', 'EFI', 'fat32', '1MiB', '1025MiB'])
    subprocess.run(['parted', '-s', drive, 'set', '1', 'esp', 'on'])
    subprocess.run(['parted', '-s', drive, 'mkpart', 'swap', 'linux-swap', '1025MiB', '5121MiB'])
    subprocess.run(['parted', '-s', drive, 'mkpart', 'root', 'ext4', '5121MiB', '100%'])
    subprocess.run(['partprobe', drive])
    time.sleep(2)
    print("Formatting partitions...")
    subprocess.run(['mkfs.fat', '-F32', p1])
    subprocess.run(['mkswap', p2])
    subprocess.run(['mkfs.ext4', p3])

def manual_partition(drive):
    print(CYAN + "\n╔══════════════════════════════════════════════╗" + RESET)
    print(CYAN + "║" + WHITE + "    Manual Partitioning:                  " + CYAN + "║" + RESET)
    print(CYAN + "╠══════════════════════════════════════════════╣" + RESET)
    print(CYAN + "║" + RESET + " Create at least:                         " + CYAN + "║" + RESET)
    print(CYAN + "║" + RESET + "  - An EFI partition (FAT32)              " + CYAN + "║" + RESET)
    print(CYAN + "║" + RESET + "  - A swap partition                      " + CYAN + "║" + RESET)
    print(CYAN + "║" + RESET + "  - A root partition (ext4)               " + CYAN + "║" + RESET)
    print(CYAN + "╚══════════════════════════════════════════════╝" + RESET)
    input("\nPress Enter to open cfdisk...")
    subprocess.run(['cfdisk', drive])
    print("\nNow enter your partition paths:")
    p1 = input("EFI partition (e.g. /dev/sda1): ").strip()
    p2 = input("Swap partition (e.g. /dev/sda2): ").strip()
    p3 = input("Root partition (e.g. /dev/sda3): ").strip()
    print("Formatting partitions...")
    subprocess.run(['mkfs.fat', '-F32', p1])
    subprocess.run(['mkswap', p2])
    subprocess.run(['mkfs.ext4', p3])
    print("Mounting partitions...")
    subprocess.run(['mount', p3, '/mnt'])
    subprocess.run(['mkdir', '-p', '/mnt/boot/efi'])
    subprocess.run(['mount', p1, '/mnt/boot/efi'])
    subprocess.run(['swapon', p2])
    print("Partitions mounted!")

