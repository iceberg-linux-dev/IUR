def mount_partitions(drive):
    p1, p2, p3 = get_partition_names(drive)
    subprocess.run(['mount', p3, '/mnt'])
    subprocess.run(['mkdir', '-p', '/mnt/boot/efi'])
    subprocess.run(['mount', p1, '/mnt/boot/efi'])
    subprocess.run(['swapon', p2])
    print("Partitions mounted!")

def install_base(de, size):
    base_packages = [
        'base', 'linux', 'linux-firmware', 'base-devel',
        'networkmanager', 'grub', 'efibootmgr', 'sudo',
        'pipewire', 'pipewire-pulse', 'wireplumber',
        'noto-fonts', 'nano', 'vim', 'python',
        'git', 'wget', 'curl'
    ]
    ucode = get_ucode()
    if ucode:
        base_packages.append(ucode)
        print(f"Detected CPU, adding {ucode}...")

    de_full = {
        'kde':    ['plasma', 'kde-applications', 'sddm', 'xorg-server'],
        'gnome':  ['gnome', 'gnome-extra', 'gdm', 'xorg-server'],
        'xfce':   ['xfce4', 'xfce4-goodies', 'lightdm', 'lightdm-gtk-greeter', 'xorg-server'],
        'manual': []
    }
    de_minimal = {
        'kde':    ['plasma', 'sddm', 'xorg-server',
                   'firefox', 'alacritty', 'htop', 'fastfetch'],
        'gnome':  ['gnome-shell', 'gnome-terminal', 'nautilus', 'gdm', 'xorg-server',
                   'firefox', 'alacritty', 'htop', 'fastfetch'],
        'xfce':   ['xfce4', 'lightdm', 'lightdm-gtk-greeter', 'xorg-server',
                   'firefox', 'alacritty', 'htop', 'fastfetch'],
        'manual': ['htop', 'fastfetch']
    }
    packages = base_packages + (de_full if size == 'full' else de_minimal).get(de, [])
    print(f"\nInstalling {size.upper()} {de.upper()} system...")
    try:
        subprocess.run(['pacstrap', '/mnt'] + packages, check=True)
    except subprocess.CalledProcessError:
        print(RED + "\nERROR: pacstrap failed! Check your internet and try again." + RESET)
        sys.exit(1)
    print("Generating fstab...")
    result = subprocess.run(['genfstab', '-U', '/mnt'], capture_output=True, text=True)
    with open('/mnt/etc/fstab', 'w') as f:
        f.write(result.stdout)
    print("Base system installed!")

def install_ipm():
    try:
        # Make sure directory exists first
        subprocess.run(['mkdir', '-p', '/mnt/usr/local/bin'], check=True)
        subprocess.run(['cp', '/usr/local/bin/ipm', '/mnt/usr/local/bin/ipm'], check=True)
        subprocess.run(['chmod', '+x', '/mnt/usr/local/bin/ipm'], check=True)
        print("ipm installed!")
    except Exception:
        print("ipm not found, skipping...")

def install_grub(selected):
    print("Installing GRUB...")
    try:
        if is_efi():
            subprocess.run([
                'grub-install',
                '--target=x86_64-efi',
                '--efi-directory=/mnt/boot/efi',
                '--boot-directory=/mnt/boot',
                '--bootloader-id=Iceberg',
                '--removable'
            ], check=True)
        else:
            subprocess.run([
                'grub-install',
                '--target=i386-pc',
                '--boot-directory=/mnt/boot',
                selected
            ], check=True)
        subprocess.run(['arch-chroot', '/mnt', 'grub-mkconfig',
                        '-o', '/boot/grub/grub.cfg'], check=True)
        print("GRUB installed successfully!")
    except subprocess.CalledProcessError:
        print(RED + "\nERROR: GRUB install failed!" + RESET)
        sys.exit(1)

def configure_system(de, selected):
    hostname = input("\nEnter hostname: ").strip()
    with open('/mnt/etc/hostname', 'w') as f:
        f.write(hostname + '\n')
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c',
                    'echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen && locale-gen'])
    with open('/mnt/etc/locale.conf', 'w') as f:
        f.write('LANG=en_US.UTF-8\n')
    timezone = input("Enter timezone (e.g. America/New_York): ").strip()
    subprocess.run(['arch-chroot', '/mnt', 'ln', '-sf',
                    f'/usr/share/zoneinfo/{timezone}', '/etc/localtime'])
    subprocess.run(['arch-chroot', '/mnt', 'hwclock', '--systohc'])
    subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'NetworkManager'])
    if de == 'kde':
        subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'sddm'])
    elif de == 'gnome':
        subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'gdm'])
    elif de == 'xfce':
        subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'lightdm'])
    print("Generating initramfs...")
    try:
        subprocess.run(['arch-chroot', '/mnt', 'mkinitcpio', '-P'], check=True)
    except subprocess.CalledProcessError:
        print(RED + "\nERROR: mkinitcpio failed!" + RESET)
        sys.exit(1)
    bind_mounts()
    install_grub(selected)
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c',
                    'echo "%wheel ALL=(ALL:ALL) ALL" >> /etc/sudoers'])
    root_pass = input("Set root password: ")
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c',
                    f'echo "root:{root_pass}" | chpasswd'])
    username = input("Enter username: ").strip()
    subprocess.run(['arch-chroot', '/mnt', 'useradd', '-m', '-G', 'wheel', '-s', '/bin/bash', username])
    user_pass = input(f"Set password for {username}: ")
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c',
                    f'echo "{username}:{user_pass}" | chpasswd'])
    print("\nSystem configured!")

def run_installer():
    """Entry point for the Iceberg Linux installer."""
    installer_banner()
    de_choice = select_de()
    if de_choice != 'manual':
        size_choice = select_install_size()
    else:
        size_choice = 'minimal'

    output = subprocess.run(['lsblk', '-J', '-o', 'NAME,TYPE,SIZE'], capture_output=True, text=True)
    data   = json.loads(output.stdout)
    disks  = [d for d in data['blockdevices'] if d['type'] == 'disk']

    print(CYAN + "\n╔══════════════════════════════════════════════╗" + RESET)
    print(CYAN + "║" + WHITE + "    Available Drives:                     " + CYAN + "║" + RESET)
    print(CYAN + "╠══════════════════════════════════════════════╣" + RESET)
    for i, disk in enumerate(disks):
        line = f" {i+1}. /dev/{disk['name']} - {disk['size']}"
        print(CYAN + "║" + RESET + line.ljust(46) + CYAN + "║" + RESET)
    print(CYAN + "╚══════════════════════════════════════════════╝" + RESET)

    drive_choice = int(input("\nSelect a drive: ")) - 1
    selected     = f"/dev/{disks[drive_choice]['name']}"

    needs_mount = partition_menu(selected)
    if needs_mount:
        mount_partitions(selected)

    install_base(de_choice, size_choice)
    install_ipm()
    configure_system(de_choice, selected)

    print(CYAN + """
╔══════════════════════════════════════════════╗
║         Installation complete!               ║
║      Would you like to reboot now?           ║
╚══════════════════════════════════════════════╝
""" + RESET)

    reboot = input("Reboot now? (yes/no): ").strip().lower()
    if reboot == 'yes':
        subprocess.run(['umount', '-R', '/mnt'])
        subprocess.run(['reboot'])
    else:
        print("\nYou can reboot manually when ready. Enjoy Iceberg Linux!")

# ======================================================================
#  INTERACTIVE SHELL  --  Keeps the app running and waiting for input
# ======================================================================

def interactive_shell():
    print_banner()
    print(f"  {BOLD}Welcome to the Iceberg Shell.{RESET}")
    print(f"  {DIM}Type a command (e.g., '{CYAN}dive{DIM}' or '{CYAN}submerge firefox{DIM}') and press Enter.")
    print(f"  Type '{CYAN}help{DIM}' for options or '{CYAN}exit{DIM}' to quit.\n")

    while True:
        try:
            user_input = input(f"{CYAN}ipm>{RESET} ").strip()

            if not user_input:
                continue

            parts = user_input.split()
            command = parts[0].lower()
            args = parts[1:]

            if command in ('exit', 'quit'):
                print(f"{DIM}  The ice holds. Goodbye!{RESET}")
                sys.exit(0)

            if command in COMMANDS:
                COMMANDS[command](args)
                print()
            else:
                print(f"  {RED}✗ Unknown command: '{command}'. Type 'help' for options.{RESET}\n")

        except KeyboardInterrupt:
            print(f"\n  {DIM}The ice holds. Goodbye!{RESET}")
            sys.exit(0)
        except Exception as e:
            print(f"  {RED}✗ An error occurred: {e}{RESET}\n")

# ======================================================================
#  DISPATCH  --  the only thing that executes at startup
# ======================================================================

COMMANDS = {
    'submerge'  : lambda args: cmd_submerge(args),
    'melt'      : lambda args: cmd_melt(args),
    'dive'      : lambda args: cmd_dive(),
    'surface'   : lambda args: cmd_surface(args),
    'depth'     : lambda args: cmd_depth(args[0] if args else ''),
    'iceberg'   : lambda args: cmd_iceberg(),
    'freeze'    : lambda args: cmd_freeze(args),
    'thaw'      : lambda args: cmd_thaw(args),
    'installer' : lambda args: run_installer(),
    'link'      : lambda args: cmd_link(),
    'help'      : lambda args: cmd_help(),
    '--help'    : lambda args: cmd_help(),
    '-h'        : lambda args: cmd_help(),
}

def main():
    # 1. AUTO-SUDO ELEVATION!
    # If the user forgets 'sudo', we just re-launch this exact script with sudo automatically.
    if os.geteuid() != 0:
        print(f"{YELLOW}  ⚠ Root privileges required. Elevating...{RESET}")
        try:
            # os.execvp replaces the current python process with 'sudo python3 <script> <args>'
            os.execvp("sudo", ["sudo", sys.executable] + sys.argv)
        except Exception as e:
            print(f"{RED}  ✗ Failed to elevate privileges: {e}{RESET}")
            print(f"  {DIM}Please run manually: sudo python3 {sys.argv[0]}{RESET}")
            sys.exit(1)

    # 2. SMART SHORTCUT (Installer symlink)
    if os.path.basename(sys.argv[0]) == 'installer':
        run_installer()
        sys.exit(0)

    # 3. COMMAND ROUTING
    args = sys.argv[1:]
    if not args:
        # No arguments provided on startup -> Launch the interactive shell!
        interactive_shell()
        sys.exit(0)

    # If arguments were provided directly (e.g. `ipm dive`), run them normally.
    command = args[0].lower()
    rest    = args[1:]

    if command in COMMANDS:
        COMMANDS[command](rest)
    else:
        print(f"\n  {RED}✗ Unknown command: '{command}'{RESET}")
        print(f"  Run {CYAN}ipm help{RESET} to see available commands.\n")
        sys.exit(1)

if __name__ == '__main__':
    main()
