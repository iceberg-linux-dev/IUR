#!/usr/bin/env python3
"""
ipm — Iceberg Package Manager
Commands:
  submerge   ->  install package(s)
  melt       ->  uninstall package(s)
  dive       ->  update system
  surface    ->  search for a package
  depth      ->  show package info
  iceberg    ->  list installed packages
  freeze     ->  lock a package version (hold)
  thaw       ->  unlock a package version (unhold)
  installer  ->  launch the Iceberg Linux installer
  link       ->  create 'installer' system shortcut
  help       ->  show this message
"""

import subprocess
import json
import sys
import time
import os
import re

