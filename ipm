def auto_partition(drive):
    subprocess.run(['umount', '-R', '/mnt'], capture_output=True)
    subprocess.run(['swapoff', '-a'], capture_output=True)
    for name in subprocess.run(['lsblk', '-rno', 'NAME', drive], capture_output=True, text=True).stdout.strip().split('\n'):
        if name: subprocess.run(['umount', '-f', f'/dev/{name}'], capture_output=True)
    p1, p2, p3 = get_partition_names(drive)
    print("\nCreating & formatting partitions...")
    subprocess.run(['parted', '-s', drive, 'mklabel', 'gpt', 'mkpart', 'EFI', 'fat32', '1MiB', '1025MiB', 'set', '1', 'esp', 'on', 'mkpart', 'swap', 'linux-swap', '1025MiB', '5121MiB', 'mkpart', 'root', 'ext4', '5121MiB', '100%'], check=True)
    subprocess.run(['partprobe', drive], check=True)
    time.sleep(2)
    subprocess.run(['mkfs.fat', '-F32', p1], check=True)
    subprocess.run(['mkswap', p2], check=True)
    subprocess.run(['mkfs.ext4', p3], check=True)

def manual_partition(drive):
    input("\nPress Enter to open cfdisk...")
    subprocess.run(['cfdisk', drive])
    p1 = input("EFI partition (e.g. /dev/sda1): ").strip()
    p2 = input("Swap partition (e.g. /dev/sda2): ").strip()
    p3 = input("Root partition (e.g. /dev/sda3): ").strip()
    subprocess.run(['mkfs.fat', '-F32', p1], check=True)
    subprocess.run(['mkswap', p2], check=True)
    subprocess.run(['mkfs.ext4', p3], check=True)
    subprocess.run(['mount', p3, '/mnt'], check=True)
    subprocess.run(['mkdir', '-p', '/mnt/boot/efi'], check=True)
    subprocess.run(['mount', p1, '/mnt/boot/efi'], check=True)
    subprocess.run(['swapon', p2], check=True)

def partition_menu(drive):
    print(CYAN + "\n╔══════════════════════════════════════════════╗" + RESET)
    print(CYAN + "║" + (RED + "  ⚠  Existing OS Detected! Wipe recommended. " if detect_os(drive) else WHITE + "    Partition Your Drive:                 ") + CYAN + "║" + RESET)
    print(CYAN + "╠══════════════════════════════════════════════╣" + RESET)
    print(CYAN + "║" + RESET + " 1. Auto (1GB EFI, 4GB swap, rest root)  " + CYAN + "║" + RESET)
    print(CYAN + "║" + RESET + " 2. Manual (cfdisk)                       " + CYAN + "║" + RESET)
    print(CYAN + "║" + RESET + " 3. Quit                                  " + CYAN + "║" + RESET)
    print(CYAN + "══════════════════════════════════════════════╝" + RESET)
    choice = input("\nSelect an option: ").strip()
    if choice == '3': sys.exit(0)
    if choice == '1': auto_partition(drive); return True
    if choice == '2': manual_partition(drive); return False
    return partition_menu(drive)

def install_base(de, size):
    # UFW AND FASTFETCH ADDED TO BASE PACKAGES FOR 1.0 SECURITY & BRANDING
    base_packages = ['base', 'linux', 'linux-firmware', 'base-devel', 'networkmanager', 'grub', 'efibootmgr', 'sudo', 'pipewire', 'pipewire-pulse', 'wireplumber', 'noto-fonts', 'nano', 'vim', 'python', 'git', 'wget', 'curl', 'iwd', 'reflector', 'fastfetch', 'ufw']
    ucode = get_ucode()
    if ucode: base_packages.append(ucode)
    
    vendor, _ = detect_wifi_chip()
    fw_map = {'marvell': ['linux-firmware-marvell'], 'realtek': ['linux-firmware-realtek'], 'broadcom': ['linux-firmware-broadcom'], 'mediatek': ['linux-firmware-mediatek'], 'qualcomm': ['linux-firmware-qcom']}
    for pkg in fw_map.get(vendor, ['linux-firmware']):
        if pkg not in base_packages: base_packages.append(pkg)
    
    de_pkgs = {'kde': ['plasma', 'kde-applications', 'sddm', 'xorg-server'], 'gnome': ['gnome', 'gnome-extra', 'gdm', 'xorg-server'], 'xfce': ['xfce4', 'xfce4-goodies', 'lightdm', 'lightdm-gtk-greeter', 'xorg-server'], 'manual': []}
    min_pkgs = {'kde': ['plasma', 'sddm', 'xorg-server', 'firefox', 'alacritty', 'htop'], 'gnome': ['gnome-shell', 'gnome-terminal', 'nautilus', 'gdm', 'xorg-server', 'firefox', 'alacritty', 'htop'], 'xfce': ['xfce4', 'lightdm', 'lightdm-gtk-greeter', 'xorg-server', 'firefox', 'alacritty', 'htop'], 'manual': ['htop']}
    packages = base_packages + (de_pkgs if size == 'full' else min_pkgs).get(de, [])
    
    print(f"\nInstalling {size.upper()} {de.upper()} system...")
    
    print(f"{DIM}  Forcing reliable DNS servers...{RESET}")
    try:
        if os.path.islink('/etc/resolv.conf'): os.remove('/etc/resolv.conf')
        with open('/etc/resolv.conf', 'w') as f: f.write("nameserver 1.1.1.1\nnameserver 8.8.8.8\n")
    except Exception as e: print(f"{YELLOW}  ⚠ DNS override warning: {e}{RESET}")

    print(f"{DIM}  Refreshing package mirrors...{RESET}")
    if subprocess.run(['reflector', '--country', 'US', '--latest', '5', '--sort', 'rate', '--save', '/etc/pacman.d/mirrorlist'], capture_output=True).returncode != 0:
        res = subprocess.run(['curl', '-s', 'https://archlinux.org/mirrorlist/?country=US&protocol=https&use_mirror_status=on'], capture_output=True, text=True)
        if res.returncode == 0:
            with open('/etc/pacman.d/mirrorlist', 'w') as f:
                f.write('\n'.join([l for l in res.stdout.replace('#Server', 'Server').split('\n') if l.startswith('Server')][:5]))
    
    try:
        subprocess.run(['pacstrap', '-K', '/mnt'] + packages, check=True)
    except subprocess.CalledProcessError:
        print(RED + "\nERROR: pacstrap failed! Check internet and try again." + RESET); sys.exit(1)
    
    result = subprocess.run(['genfstab', '-U', '/mnt'], capture_output=True, text=True)
    with open('/mnt/etc/fstab', 'w') as f: f.write(result.stdout)
    print("Base system installed!")

def install_ipm():
    print(f"{DIM}  Installing ipm and baking native commands into the system...{RESET}")
    try:
        subprocess.run(['mkdir', '-p', '/mnt/usr/local/bin'], check=True)
        subprocess.run(['cp', '/usr/local/bin/ipm', '/mnt/usr/local/bin/ipm'], check=True)
        subprocess.run(['chmod', '+x', '/mnt/usr/local/bin/ipm'], check=True)
        
        commands = ['submerge', 'melt', 'dive', 'surface', 'depth', 'iceberg', 'freeze', 'thaw', 'update', 'installer', 'link', 'help']
        for cmd in commands:
            subprocess.run(['ln', '-sf', '/usr/local/bin/ipm', f'/mnt/usr/bin/{cmd}'], check=True)
        
        pacman_redirect = '''#!/bin/bash
echo -e "\\n🧊 Iceberg Linux uses IPM, not pacman!\\n"
echo -e "Use these native commands instead:"
echo -e "  \\033[96mdive\\033[0m        -> Update the entire system"
echo -e "  \\033[96msubmerge\\033[0m    -> Install packages"
echo -e "  \\033[96mmelt\\033[0m        -> Remove packages"
echo -e "  \\033[96msurface\\033[0m     -> Search for packages"
echo -e "  \\033[96mupdate\\033[0m      -> Update the ipm tool itself\\n"
exit 1
'''
        with open('/mnt/usr/bin/pacman', 'w') as f:
            f.write(pacman_redirect)
        subprocess.run(['chmod', '+x', '/mnt/usr/bin/pacman'], check=True)
        
        print(f"{GREEN}  ✓ ipm, native shortcuts, and pacman redirection installed successfully!{RESET}")
    except subprocess.CalledProcessError as e:
        print(f"{RED}  ✗ CRITICAL: Failed to install ipm: {e}{RESET}")
        sys.exit(1)

def install_grub(selected):
    print("Installing GRUB...")
    try:
        if is_efi():
            subprocess.run(['grub-install', '--target=x86_64-efi', '--efi-directory=/mnt/boot/efi', '--boot-directory=/mnt/boot', '--bootloader-id=Iceberg', '--removable'], check=True)
        else:
            subprocess.run(['grub-install', '--target=i386-pc', '--boot-directory=/mnt/boot', selected], check=True)
        subprocess.run(['arch-chroot', '/mnt', 'grub-mkconfig', '-o', '/boot/grub/grub.cfg'], check=True)
        print("GRUB installed successfully!")
    except subprocess.CalledProcessError:
        print(RED + "\nERROR: GRUB install failed!" + RESET); sys.exit(1)

def configure_system(de, selected):
    hostname = input("\nEnter hostname: ").strip()
    with open('/mnt/etc/hostname', 'w') as f: f.write(hostname + '\n')
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c', 'echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen && locale-gen'], check=True)
    with open('/mnt/etc/locale.conf', 'w') as f: f.write('LANG=en_US.UTF-8\n')
    subprocess.run(['arch-chroot', '/mnt', 'ln', '-sf', f"/usr/share/zoneinfo/{input('Enter timezone (e.g. America/New_York): ').strip()}", '/etc/localtime'], check=True)
    subprocess.run(['arch-chroot', '/mnt', 'hwclock', '--systohc'], check=True)
    
    # WIFI & FIREWALL SETUP
    subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'NetworkManager'], check=True)
    subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'iwd'], check=True)
    nm_conf = "/mnt/etc/NetworkManager/NetworkManager.conf"
    subprocess.run(['arch-chroot', '/mnt', 'touch', '/etc/NetworkManager/NetworkManager.conf'], capture_output=True)
    with open(nm_conf, 'a') as f: f.write("\n[device]\nwifi.backend=iwd\n")
    
    # ENABLE AND CONFIGURE UFW FIREWALL
    print(f"{DIM}  Configuring UFW Firewall (Deny incoming, Allow outgoing)...{RESET}")
    subprocess.run(['arch-chroot', '/mnt', 'ufw', '--force', 'reset'], capture_output=True)
    subprocess.run(['arch-chroot', '/mnt', 'ufw', 'default', 'deny', 'incoming'], capture_output=True)
    subprocess.run(['arch-chroot', '/mnt', 'ufw', 'default', 'allow', 'outgoing'], capture_output=True)
    subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', '--now', 'ufw'], check=True)
    
    if de == 'kde': subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'sddm'], check=True)
    elif de == 'gnome': subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'gdm'], check=True)
    elif de == 'xfce': subprocess.run(['arch-chroot', '/mnt', 'systemctl', 'enable', 'lightdm'], check=True)
    
    subprocess.run(['arch-chroot', '/mnt', 'mkinitcpio', '-P'], check=True)
    bind_mounts()
    install_grub(selected)
    
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c', 'echo "%wheel ALL=(ALL:ALL) ALL" >> /etc/sudoers'], check=True)
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c', f'echo "root:{input("Set root password: ")}" | chpasswd'], check=True)
    username = input("Enter username: ").strip()
    subprocess.run(['arch-chroot', '/mnt', 'useradd', '-m', '-G', 'wheel', '-s', '/bin/bash', username], check=True)
    subprocess.run(['arch-chroot', '/mnt', 'bash', '-c', f'echo "{username}:{input(f"Set password for {username}: ")}" | chpasswd'], check=True)
    
    # Ensure Fastfetch config is copied to the new user's home directory
    subprocess.run(['arch-chroot', '/mnt', 'mkdir', '-p', f'/home/{username}/.config/fastfetch'], check=True)
    subprocess.run(['arch-chroot', '/mnt', 'cp', '/etc/skel/.config/fastfetch/config.jsonc', f'/home/{username}/.config/fastfetch/'], check=True)
    subprocess.run(['arch-chroot', '/mnt', 'chown', '-R', f'{username}:{username}', f'/home/{username}/.config'], check=True)
    
    print("\nSystem configured!")

def run_installer():
    print_banner()
    de_choice = select_de()
    size_choice = 'minimal' if de_choice == 'manual' else select_install_size()
    
    disks = [d for d in json.loads(subprocess.run(['lsblk', '-J', '-o', 'NAME,TYPE,SIZE'], capture_output=True, text=True).stdout)['blockdevices'] if d['type'] == 'disk' and 'boot' not in d['name']]
    print(CYAN + "\n╔══════════════════════════════════════════════╗" + RESET)
    for i, disk in enumerate(disks): print(CYAN + "║" + RESET + f" {i+1}. /dev/{disk['name']} - {disk['size']}".ljust(46) + CYAN + "║" + RESET)
    print(CYAN + "╚══════════════════════════════════════════════╝" + RESET)
    
    selected = f"/dev/{disks[int(input('\nSelect a drive: ')) - 1]['name']}"
    if partition_menu(selected):
        p1, p2, p3 = get_partition_names(selected)
        subprocess.run(['mount', p3, '/mnt'], check=True)
        subprocess.run(['mkdir', '-p', '/mnt/boot/efi'], check=True)
        subprocess.run(['mount', p1, '/mnt/boot/efi'], check=True)
        subprocess.run(['swapon', p2], check=True)
    
    install_base(de_choice, size_choice)
    install_ipm()
    configure_system(de_choice, selected)
    
    print(CYAN + "\n══════════════════════════════════════════════╗\n║         Installation complete!               ║\n║      Would you like to reboot now?           ║\n╚══════════════════════════════════════════════╝" + RESET)
    if input("Reboot now? (yes/no): ").strip().lower() == 'yes':
        subprocess.run(['umount', '-R', '/mnt'])
        subprocess.run(['reboot'])

def interactive_shell():
    print_banner()
    print(f"  {BOLD}Welcome to the Iceberg Shell.{RESET}")
    print(f"  {DIM}Type a command (e.g., '{CYAN}dive{DIM}' or '{CYAN}submerge firefox{DIM}') and press Enter.")
    print(f"  Type '{CYAN}help{DIM}' for options or '{CYAN}exit{DIM}' to quit.\n")
    while True:
        try:
            parts = input(f"{CYAN}ipm>{RESET} ").strip().split()
            if not parts: continue
            if parts[0].lower() in ('exit', 'quit'): print(f"{DIM}  The ice holds. Goodbye!{RESET}"); sys.exit(0)
            if parts[0].lower() in COMMANDS: COMMANDS[parts[0].lower()](parts[1:]); print()
            else: print(f"  {RED} Unknown command: '{parts[0]}'. Type 'help'.{RESET}\n")
        except KeyboardInterrupt: print(f"\n  {DIM}The ice holds. Goodbye!{RESET}"); sys.exit(0)
        except Exception as e: print(f"  {RED}✗ An error occurred: {e}{RESET}\n")

