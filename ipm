COMMANDS = {
    'submerge': lambda args: cmd_submerge(args), 'melt': lambda args: cmd_melt(args),
    'dive': lambda args: cmd_dive(), 'surface': lambda args: cmd_surface(args),
    'depth': lambda args: cmd_depth(args[0] if args else ''), 'iceberg': lambda args: cmd_iceberg(),
    'freeze': lambda args: cmd_freeze(args), 'thaw': lambda args: cmd_thaw(args),
    'installer': lambda args: run_installer(), 'link': lambda args: cmd_link(),
    'update': lambda args: cmd_update(),
    'help': lambda args: cmd_help(), '--help': lambda args: cmd_help(), '-h': lambda args: cmd_help(),
}

def main():
    if os.geteuid() != 0:
        try: os.execvp("sudo", ["sudo", sys.executable] + sys.argv)
        except Exception as e: print(f"{RED}  ✗ Failed to elevate: {e}{RESET}"); sys.exit(1)

    script_name = os.path.basename(sys.argv[0])
    if script_name in COMMANDS and script_name not in ['ipm', 'help', '--help', '-h']:
        COMMANDS[script_name](sys.argv[1:])
        sys.exit(0)
    
    if script_name == 'installer':
        run_installer()
        sys.exit(0)

    args = sys.argv[1:]
    if not args:
        interactive_shell()
        sys.exit(0)

    command = args[0].lower()
    if command in COMMANDS:
        COMMANDS[command](args[1:])
    else:
        print(f"\n  {RED}✗ Unknown command: '{command}'{RESET}\n  Run {CYAN}help{RESET} to see available commands.\n")
        sys.exit(1)

if __name__ == '__main__':
    main()
