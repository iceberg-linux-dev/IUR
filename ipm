def cmd_submerge(packages):
    if not packages: print(f"{RED}  ✗ Usage: submerge <package> [package...]{RESET}"); sys.exit(1)
    require_root()
    print_section(f"Submerging: {', '.join(packages)}")
    if pacman('-S', '--needed', *packages).returncode == 0:
        print(f"\n{GREEN}  ✓ Submerged successfully.{RESET}")
    else:
        print(f"\n{RED}  ✗ Something surfaced wrong.{RESET}"); sys.exit(1)

def cmd_melt(packages):
    if not packages: print(f"{RED}  ✗ Usage: melt <package> [package...]{RESET}"); sys.exit(1)
    require_root()
    print_section(f"Melting: {', '.join(packages)}")
    if not confirm("Continue with melt?"): print(f"{DIM}  Aborted. The ice holds.{RESET}"); sys.exit(0)
    if pacman('-Rns', *packages).returncode == 0:
        print(f"\n{GREEN}  ✓ Melted clean.{RESET}")
    else:
        print(f"\n{RED}   Melt incomplete.{RESET}"); sys.exit(1)

def cmd_dive():
    require_root()
    print_section("Diving Deeper — System Update")
    if pacman('-Syu').returncode == 0:
        print(f"\n{GREEN}  ✓ Surfaced with everything up to date.{RESET}")
    else:
        print(f"\n{RED}  ✗ Something went wrong mid-dive.{RESET}"); sys.exit(1)

def cmd_surface(packages):
    if not packages: print(f"{RED}  ✗ Usage: surface <query>{RESET}"); sys.exit(1)
    print_section(f"Surfacing results for: {' '.join(packages)}")
    result = pacman('-Ss', *packages, capture=True)
    if result.stdout.strip():
        for line in result.stdout.strip().split('\n'):
            if line.strip() and '/' in line.split()[0]:
                parts = line.split()
                repo, _, name = parts[0].partition('/')
                print(f"  {CYAN}{repo}/{RESET}{BOLD}{name}{RESET} {DIM}{parts[1] if len(parts)>1 else ''}{RESET}")
    else:
        print(f"  {YELLOW}No packages found.{RESET}")

def cmd_depth(package):
    if not package: print(f"{RED}  ✗ Usage: depth <package>{RESET}"); sys.exit(1)
    print_section(f"Depth reading: {package}")
    result = pacman('-Qi', package, capture=True)
    if result.returncode != 0: result = pacman('-Si', package, capture=True)
    if result.returncode == 0:
        for line in result.stdout.splitlines():
            if ':' in line:
                key, _, val = line.partition(':')
                print(f"  {CYAN}{key.strip():<20}{RESET}: {val.strip()}")
    else:
        print(f"  {RED}Package '{package}' not found.{RESET}"); sys.exit(1)

def cmd_iceberg():
    print_section("Your Iceberg — Installed Packages")
    result = pacman('-Qe', capture=True)
    if result.returncode == 0:
        for line in result.stdout.strip().split('\n'):
            parts = line.split()
            if parts: print(f"  {CYAN}❄{RESET}  {BOLD}{parts[0]:<30}{RESET} {DIM}{parts[1] if len(parts)>1 else ''}{RESET}")
    else:
        print(f"  {RED}Could not list packages.{RESET}"); sys.exit(1)

def cmd_freeze(packages):
    if not packages: print(f"{RED}  ✗ Usage: freeze <package> [package...]{RESET}"); sys.exit(1)
    require_root()
    try:
        with open('/etc/pacman.conf', 'r') as f: lines = f.readlines()
        found = False
        for i, line in enumerate(lines):
            if re.match(r'^\s*IgnorePkg\s*=', line):
                lines[i] = f'IgnorePkg = {" ".join(list(set(line.split("=", 1)[1].strip().split() + packages)))}\n'
                found = True; break
        if not found: lines.append(f'\nIgnorePkg = {" ".join(packages)}\n')
        with open('/etc/pacman.conf', 'w') as f: f.writelines(lines)
        print(f"  {GREEN}✓ Frozen: {', '.join(packages)}{RESET}")
    except Exception as e:
        print(f"  {RED}✗ Could not update pacman.conf: {e}{RESET}"); sys.exit(1)

def cmd_thaw(packages):
    if not packages: print(f"{RED}  ✗ Usage: thaw <package> [package...]{RESET}"); sys.exit(1)
    require_root()
    try:
        with open('/etc/pacman.conf', 'r') as f: lines = f.readlines()
        for i, line in enumerate(lines):
            if re.match(r'^\s*IgnorePkg\s*=', line):
                updated = set(line.split('=', 1)[1].strip().split()) - set(packages)
                lines[i] = f'IgnorePkg = {" ".join(sorted(updated))}\n' if updated else '#IgnorePkg =\n'
                break
        with open('/etc/pacman.conf', 'w') as f: f.writelines(lines)
        print(f"  {GREEN}✓ Thawed: {', '.join(packages)}{RESET}")
    except Exception as e:
        print(f"  {RED} Could not update pacman.conf: {e}{RESET}"); sys.exit(1)

def cmd_link():
    require_root()
    script_path = os.path.abspath(sys.argv[0])
    try:
        subprocess.run(['ln', '-sf', script_path, '/usr/local/bin/installer'], check=True)
        print(f"  {GREEN}✓ Shortcut created successfully!{RESET}")
    except subprocess.CalledProcessError:
        print(f"  {RED}✗ Failed to create symlink.{RESET}")

def cmd_update():
    print(f"{DIM}  Checking for ipm updates from the IUR...{RESET}")
    url = "https://raw.githubusercontent.com/iceberg-linux-dev/IUR/main/ipm"
    result = subprocess.run(['curl', '-s', url], capture_output=True, text=True)
    
    if result.returncode == 0 and '#!/usr/bin/env python3' in result.stdout:
        with open('/usr/local/bin/ipm', 'w') as f:
